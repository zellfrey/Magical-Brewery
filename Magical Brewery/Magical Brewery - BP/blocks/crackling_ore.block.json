            "minecraft:map_color": "#4d4139",
            "minecraft:material_instances": {
                "*": {
					"texture": "magical_brewery:crackling_ore_side"
				},
				"end": {
					"texture": "magical_brewery:crackling_ore_pole"
				},
				"up": "end",
				"down": "end"
            },
            "minecraft:geometry": "minecraft:geometry.full_block",
