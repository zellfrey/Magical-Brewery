                    "magical_brewery:on_entity_fall_on_crackling_ore_unstable": {},
                    "minecraft:entity_fall_on": {
                        "min_fall_distance": 5
                    },
					"minecraft:material_instances": {
                        "*": {
                            "texture": "magical_brewery:crackling_ore_side_unstable"
                        },
                        "end": {
                            "texture": "magical_brewery:crackling_ore_pole_unstable"
