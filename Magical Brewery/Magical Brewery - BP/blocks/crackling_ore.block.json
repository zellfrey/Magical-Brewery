{
    "format_version": "1.21.100",
    "minecraft:block": {
        "description": {
            "identifier": "magical_brewery:crackling_ore",
            "menu_category": {
                "category": "nature"
            },
            "states": {
				"magical_brewery:ore_stability":["stable", "unstable", "stabilising"]
			}
        },
        "components": {
            "tag:minecraft:is_pickaxe_item_destructible": {},
			"tag:stone": {},
            "magical_brewery:on_entity_fall_on_crackling_ore": {},
            "magical_brewery:ort_crackling_ore": {},
